<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:TasteVinhKhanh.MauiApp.Views"
       x:Class="TasteVinhKhanh.MauiApp.AppShell"
       Shell.NavBarIsVisible="False"
       Shell.TabBarIsVisible="False">

    <TabBar>
        <ShellContent Route="HomePage"
                      ContentTemplate="{DataTemplate views:HomePage}"/>
        <ShellContent Route="MapPage"
                      ContentTemplate="{DataTemplate views:MapPage}"/>
        <ShellContent Route="AudioPage"
                      ContentTemplate="{DataTemplate views:AudioPage}"/>
        <ShellContent Route="SettingsPage"
                      ContentTemplate="{DataTemplate views:SettingsPage}"/>
    </TabBar>

</Shell>